{
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 10600,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "sniffing": {
        "destOverride": [
          "http",
          "tls",
          "quic"
        ],
        "enabled": true
      },
      "tag": "main-in"
    }
  ],
  "log": {
    "loglevel": "warning"
  },
  "outbounds": [
    {
      "protocol": "socks",
      "settings": {
        "servers": [
          {
            "address": "127.0.0.1",
            "port": 10603
          }
        ]
      },
      "tag": "site-2"
    },
    {
      "protocol": "socks",
      "settings": {
        "servers": [
          {
            "address": "127.0.0.1",
            "port": 10601
          }
        ]
      },
      "tag": "default-proxy"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "domain": [
          "regexp:^(?:.*\\.)?google\\.com$"
        ],
        "outboundTag": "site-2",
        "type": "field"
      },
      {
        "network": "tcp,udp",
        "outboundTag": "default-proxy",
        "type": "field"
      }
    ]
  }
}